    <div class="kds-empty-msg">Sin pedidos pendientes.<br>Envía un pedido desde la vista Cliente.</div>
  </div>
  <div class="grid" id="k-grid"></div>
</div>

<!-- ══ BARRA ══ -->
<div class="screen" id="screen-bar">
  <div class="kds-top">
    <div><div class="kds-title">🍷 Barra</div><div class="kds-rest">${NOMBRE_RESTAURANTE} · ${CIUDAD}</div></div>
    <div class="kds-clock" id="clk-b">23:33</div>
  </div>
  <div class="kds-empty" id="b-empty">
    <div class="kds-empty-ico">🍸</div>
    <div class="kds-empty-msg">Sin pedidos pendientes.<br>Envía un pedido desde la vista Cliente.</div>
  </div>
  <div class="grid" id="b-grid"></div>
</div>

<!-- ══ RESUMEN MESA ══ -->
<div class="screen" id="screen-summary">
  <div class="sum-hero">
    <div class="sum-title">📋 Resumen de mesa</div>
    <div class="sum-mesa" id="sum-mesa-label">Mesa 3</div>
  </div>
  <div id="sum-items"></div>
  <div class="sum-total-bar">
    <span class="sum-total-label">Total acumulado</span>
    <span class="sum-total-amount" id="sum-grand-total">0,00€</span>
  </div>
  <button class="bill-btn" id="bill-btn" onclick="requestBill()" style="display:none">🧾 Solicitar la cuenta</button>
  <div class="bill-requested-box" id="bill-requested-box" style="display:none"></div>
</div>

<!-- ══ ADMIN ══ -->
<div class="screen" id="screen-admin">
  <div class="admin-top">
    <div>
      <div class="admin-title">🔑 Panel Admin</div>
      <div class="admin-sub">${NOMBRE_RESTAURANTE} · ${CIUDAD}</div>
    </div>
    <div class="kds-clock" id="clk-admin">--:--</div>
  </div>

  <!-- LOCK -->
  <div class="admin-lock" id="admin-lock">
    <h3>Acceso restringido</h3>
    <p>Introduce el PIN de administrador</p>
    <input class="admin-pin-input" id="admin-pin" type="password" maxlength="6" placeholder="····" onkeydown="if(event.key==='Enter')unlockAdmin()">
    <button class="admin-pin-btn" onclick="unlockAdmin()">Entrar</button>
    <div class="admin-pin-error" id="admin-pin-error">PIN incorrecto. Inténtalo de nuevo.</div>
  </div>

  <!-- CONTENT (hidden until unlocked) -->
  <div id="admin-content" style="display:none">
    <div class="admin-tabs">
      <div class="admin-tab active" data-tab="tables" onclick="switchAdminTab('tables')">🍽️ Mesas</div>
      <div class="admin-tab" data-tab="stock" onclick="switchAdminTab('stock')">🔴 Stock</div>
      <div class="admin-tab" data-tab="qr" onclick="switchAdminTab('qr')">📲 QR</div>
    </div>

    <!-- PANEL MESAS -->
    <div class="admin-panel active" id="apanel-tables">
      <div id="admin-bill-alerts"></div>
      <div class="table-grid" id="admin-tables-grid"></div>
      <div class="admin-mesa-detail" id="admin-mesa-detail" style="display:none">
        <div class="amd-head">
          <div class="amd-title" id="admin-mesa-title">Mesa —</div>
          <div style="display:flex;align-items:center;gap:10px;">
            <div class="amd-total" id="admin-mesa-total">0,00€</div>
            <button id="admin-enter-mesa-btn" onclick="adminEnterMesa()" style="background:#c9913a;color:#0a0604;border:none;padding:6px 12px;font-size:11px;font-weight:700;cursor:pointer;border-radius:2px;white-space:nowrap;">👁️ Ver mesa →</button>
          </div>
        </div>
        <div class="amd-tabs">
          <div class="amd-tab active" onclick="switchAmdTab('pedido',this)">📋 Pedido actual</div>
          <div class="amd-tab" onclick="switchAmdTab('anadir',this)">➕ Añadir artículo</div>
        </div>
        <div class="amd-panel active" id="amd-panel-pedido">
          <div id="admin-mesa-items"></div>
          <div class="amd-actions" style="padding:10px 14px 12px;">
            <button class="amd-btn amd-btn-reset" id="admin-mesa-bill-btn">🗑️ Cerrar mesa</button>
          </div>
        </div>
        <div class="amd-panel" id="amd-panel-anadir">
          <div style="padding:10px 14px 4px;">
            <input class="amd-add-search" id="amd-search" type="text" placeholder="Buscar plato o bebida..." oninput="filterAmdMenu(this.value)">
            <div class="amd-menu-list" id="amd-menu-list"></div>
          </div>
          <div class="amd-cart-bar">
            <div class="amd-cart-info" id="amd-cart-info">Sin artículos</div>
            <button class="amd-send-btn" id="amd-send-btn" onclick="sendAdminOrder()" disabled>Enviar pedido</button>
          </div>
        </div>
      </div>
    </div>

    <!-- PANEL STOCK -->
    <div class="admin-panel" id="apanel-stock">
      <p class="qr-intro">Marca los platos agotados. Seguirán visibles en la carta pero no se podrán añadir al pedido.</p>
      <div class="stock-agotado-count" id="stock-agotado-count"></div>
      <input class="stock-search" id="stock-search" type="text" placeholder="Buscar plato..." oninput="filterStock(this.value)">
      <div class="stock-list" id="stock-list"></div>
    </div>

    <!-- PANEL QR -->
    <div class="admin-panel" id="apanel-qr">
      <p class="qr-intro">Imprime los QR de cada mesa y el tuyo de administrador. Se imprime en tu impresora predeterminada.</p>
      <div class="qr-admin-label">Tu QR de administrador</div>
      <div id="admin-own-qr" class="qr-admin-wrap"></div>
      <div class="qr-admin-label">QR por mesa</div>
      <div class="qr-grid" id="admin-qr-grid"></div>
    </div>
  </div>
</div>

<!-- TICKET MODAL -->
<div class="ticket-overlay" id="ticket-overlay" onclick="closeTicket(event)">
  <div class="ticket-wrap">
    <div id="ticket-content"></div>
    <div class="ticket-actions">
      <button class="t-btn t-btn-print" onclick="printTicket()">🖨️ IMPRIMIR COMANDA</button>
      <button class="t-btn t-btn-close" onclick="document.getElementById(&#39;ticket-overlay&#39;).classList.remove(&#39;show&#39;)">✕ Cerrar</button>
    </div>
  </div>
</div>

<!-- ORDER MODAL -->
<div class="overlay" id="modal">
  <div class="modal">
    <div class="modal-ico">✅</div>
    <div class="modal-ttl">¡Pedido enviado!</div>
    <div class="modal-txt" id="modal-txt"></div>
    <button class="modal-btn" onclick="document.getElementById(&#39;modal&#39;).classList.remove(&#39;show&#39;)">Perfecto, gracias</button>
  </div>
</div>

<script>
// ── CONFIG ──
const APP_KEY = 'kmarero_v1';
const ADMIN_PIN = '${PIN_ADMIN}';
const NUM_TABLES = 30;
const TABLES = Array.from({length:NUM_TABLES}, (_,i) => i+1);

// ── URL PARAMS ──
const urlParams = new URLSearchParams(location.search);
const TABLE_NUM = urlParams.get('mesa') || '3';
const IS_ADMIN = urlParams.get('admin') === '1';

// ── IN-MEMORY STATE ──
let cart = [], kOrders = [], bOrders = [], oid = 1;

// ── LOCALSTORAGE STATE ──
function getState() {
  try { return JSON.parse(localStorage.getItem(APP_KEY)) || {tables:{}}; }
  catch(e) { return {tables:{}}; }
}
function setState(s) {
  try { localStorage.setItem(APP_KEY, JSON.stringify(s)); } catch(e) {}
}
function getTable(num) {
  const s = getState();
  if (!s.tables[num]) s.tables[num] = {orders:[], billRequested:false, billRequestTime:null};
  return {state:s, tbl:s.tables[num]};
}

// ── INIT ──
(function init(){
  document.querySelectorAll('.table-pill').forEach(el => el.textContent = `Mesa ${TABLE_NUM} · 2 personas`);
  document.getElementById('nav-customer').textContent = `📱 Cliente (Mesa ${TABLE_NUM})`;
  document.getElementById('sum-mesa-label').textContent = `Mesa ${TABLE_NUM}`;

  if (IS_ADMIN) {
    document.getElementById('nav-admin').style.display = '';
    showScreen('admin', document.getElementById('nav-admin'));
  }
  // Restore saved name
  const savedName = sessionStorage.getItem('kmarero_name_'+TABLE_NUM);
  if (savedName) document.getElementById('customer-name').value = savedName;

  applyStockState();
  renderKDS('k');
  renderKDS('b');
})();

function saveName(val) {
  const name = val.trim();
  sessionStorage.setItem('kmarero_name_'+TABLE_NUM, name);
  updateNavName(name);
}

function updateNavName(name) {
  document.getElementById('nav-customer').textContent = name
    ? `📱 ${name} (Mesa ${TABLE_NUM})`
    : `📱 Cliente (Mesa ${TABLE_NUM})`;
}

function getCustomerName() {
  return (document.getElementById('customer-name').value || '').trim();
}

// ── STOCK ──
function getStock() { return getState().stock || {}; }

function applyStockState() {
  const stock = getStock();
  document.querySelectorAll('.add, .dual-btn').forEach(btn => {
    const m = btn.getAttribute('onclick')?.match(/addItem\('([^']+)'/);
    if (!m) return;
    const name = m[1];
    const outOfStock = !!stock[name];
    btn.disabled = outOfStock;
    btn.classList.toggle('agotado-btn', outOfStock);
    const itemEl = btn.closest('.item');
    if (itemEl) {
      itemEl.classList.toggle('agotado-item', outOfStock);
      let badge = itemEl.querySelector('.agotado-badge');
      if (outOfStock && !badge) {
        badge = document.createElement('span');
        badge.className = 'agotado-badge';
        badge.textContent = 'Agotado';
        itemEl.querySelector('.item-body')?.appendChild(badge);
      } else if (!outOfStock && badge) {
        badge.remove();
      }
    }
  });
}

function getAllMenuItems() {
  const items = new Map();
  document.querySelectorAll('.add, .dual-btn').forEach(btn => {
    const m = btn.getAttribute('onclick')?.match(/addItem\('([^']+)',([0-9.]+),'([^']+)'/);
    if (m) items.set(m[1], {price:parseFloat(m[2]), type:m[3]});
  });
  return [...items.entries()].map(([n,v]) => [n, v.price, v.type]).sort((a,b) => a[0].localeCompare(b[0]));
}

function renderStockPanel() {
  const stock = getStock();
  const items = getAllMenuItems();
  const agotados = Object.keys(stock).filter(k => stock[k]).length;
  document.getElementById('stock-agotado-count').textContent =
    agotados ? `${agotados} plato${agotados===1?'':'s'} marcado${agotados===1?'':'s'} como agotado` : '';
  renderStockList(items, stock, '');
}

function renderStockList(items, stock, filter) {
  const list = document.getElementById('stock-list');
  const filtered = filter ? items.filter(([n]) => n.toLowerCase().includes(filter.toLowerCase())) : items;
  list.innerHTML = filtered.map(([name]) => `
    <div class="stock-row">
      <div class="stock-name">${name}</div>
      <label class="stock-toggle" title="${stock[name]?'Disponible':'Agotado'}">
        <input type="checkbox" ${stock[name]?'':'checked'} onchange="toggleStock('${name.replace(/'/g,"\\'")}',!this.checked)">
        <span class="stock-slider"></span>
      </label>
    </div>`).join('') || '<div style="padding:16px;font-size:12px;color:rgba(255,255,255,0.25)">Sin resultados</div>';
}

function filterStock(val) {
  const stock = getStock();
  const items = getAllMenuItems();
  renderStockList(items, stock, val);
}

function toggleStock(name, outOfStock) {
  const s = getState();
  if (!s.stock) s.stock = {};
  if (outOfStock) s.stock[name] = true; else delete s.stock[name];
  setState(s);
  applyStockState();
  const agotados = Object.keys(s.stock).filter(k => s.stock[k]).length;
  document.getElementById('stock-agotado-count').textContent =
    agotados ? `${agotados} plato${agotados===1?'':'s'} marcado${agotados===1?'':'s'} como agotado` : '';
}

// ── SONIDO ──
function playOrderSound() {
  try {
    const ctx = new (window.AudioContext || window.webkitAudioContext)();
    [[0,880],[160,660],[320,880]].forEach(([delay,freq]) => {
      const osc = ctx.createOscillator();
      const gain = ctx.createGain();
      osc.connect(gain); gain.connect(ctx.destination);
      osc.type = 'sine'; osc.frequency.value = freq;
      const t = ctx.currentTime + delay/1000;
      gain.gain.setValueAtTime(0.4, t);
      gain.gain.exponentialRampToValueAtTime(0.001, t+0.25);
      osc.start(t); osc.stop(t+0.25);
    });
  } catch(e) {}
}

// ── CART / ORDERING ──
function addItem(name, price, type, e) {
  const ex = cart.find(i => i.name === name);
  if (ex) ex.qty++; else cart.push({name, price, type, qty:1, notes:''});
  updateCart();
  const btn = e.target;
  btn.style.transform = 'scale(1.35)';
  setTimeout(() => btn.style.transform = '', 160);
}

function updateCart() {
  const total = cart.reduce((s,i) => s+i.price*i.qty, 0);
  const count = cart.reduce((s,i) => s+i.qty, 0);
  document.getElementById('cCount').textContent = count+(count===1?' artículo':' artículos');
  document.getElementById('cTotal').textContent = total.toFixed(2).replace('.',',')+'€';
  document.getElementById('cart').classList.toggle('show', count>0);
}

function sendOrder() {
  if (!cart.length) return;
  const now = new Date();
  const t = now.toLocaleTimeString('es-ES', {hour:'2-digit', minute:'2-digit'});
  const id = oid++;
  const name = getCustomerName();
  const tableLabel = `Mesa ${TABLE_NUM}${name ? ' · '+name : ''}`;
  const food = cart.filter(i => i.type==='food');
  const drink = cart.filter(i => i.type==='drink');

  if (food.length) { kOrders.push({id, table:tableLabel, time:t, ts:Date.now(), items:food}); renderKDS('k'); }
  if (drink.length) { bOrders.push({id, table:tableLabel, time:t, ts:Date.now(), items:drink}); renderKDS('b'); }

  // Accumulate in localStorage
  const {state, tbl} = getTable(TABLE_NUM);
  tbl.orders.push({id, time:t, ts:Date.now(), items:[...food,...drink]});
  setState(state);

  const fc = food.reduce((s,i) => s+i.qty, 0);
  const dc = drink.reduce((s,i) => s+i.qty, 0);
  const parts = [];
  if (fc) parts.push(fc+(fc===1?' plato':' platos')+' enviados a cocina 🍳');
  if (dc) parts.push(dc+(dc===1?' bebida':' bebidas')+' enviadas a barra 🍷');
  document.getElementById('modal-txt').textContent = parts.join('\n')+'\n\nEl equipo de ${NOMBRE_RESTAURANTE} lo prepara enseguida.';
  cart = []; updateCart();
  document.getElementById('modal').classList.add('show');
  flash('🔔 Nuevo pedido — '+tableLabel);
  playOrderSound();
}

// ── KDS ──
function renderKDS(s) {
  const orders = s==='k' ? kOrders : bOrders;
  const grid = document.getElementById(s+'-grid');
  const empty = document.getElementById(s+'-empty');
  empty.style.display = orders.length ? 'none' : 'block';
  grid.innerHTML = '';
  orders.forEach((o,idx) => {
    const el = Math.floor((Date.now()-o.ts)/1000);
    const m = Math.floor(el/60), sec = el%60;
    const tl = m+':'+String(sec).padStart(2,'0');
    const ec = m<5?'ok':m<10?'warn':'late';
    const btnLabel = s==='k'?'✓ LISTO — PASAR A MESA':'✓ LISTO — SERVIR EN MESA';
    const c = document.createElement('div');
    c.className = 'ocard';
    c.innerHTML = `
      <div class="ocard-head">
        <div><div class="o-table">Pedido #${o.id} · ${o.table}</div><div class="o-time">Recibido ${o.time}</div></div>
        <div class="o-elapsed ${ec}" id="el-${s}-${o.id}">${tl}</div>
      </div>
      <div class="ocard-items">${o.items.map(i=>`<div class="oi"><span class="oi-q">${i.qty}×</span><span class="oi-n">${i.name}</span></div>${i.notes?`<div class="oi-notes">⚠️ ${i.notes}</div>`:''}`).join('')}</div>
      <div class="card-actions">
        <button class="done-btn" onclick="doneOrder('${s}',${idx})">${btnLabel}</button>
        <button class="print-btn" onclick="showTicket('${s}',${idx})" title="Imprimir comanda">🖨️</button>
      </div>`;
    grid.appendChild(c);
  });
}

function doneOrder(s, idx) {
  if (s==='k') kOrders.splice(idx,1); else bOrders.splice(idx,1);
  renderKDS(s);
}

setInterval(() => {
  ['k','b'].forEach(s => {
    const orders = s==='k' ? kOrders : bOrders;
    orders.forEach(o => {
      const el = document.getElementById(`el-${s}-${o.id}`);
      if (!el) return;
      const secs = Math.floor((Date.now()-o.ts)/1000);
      const m = Math.floor(secs/60), sec = secs%60;
      el.textContent = m+':'+String(sec).padStart(2,'0');
      el.className = 'o-elapsed '+(m<5?'ok':m<10?'warn':'late');
    });
  });
  const t = new Date().toLocaleTimeString('es-ES', {hour:'2-digit', minute:'2-digit'});
  document.getElementById('clk-k').textContent = t;
  document.getElementById('clk-b').textContent = t;
  const ca = document.getElementById('clk-admin');
  if (ca) ca.textContent = t;
}, 1000);

// ── NAV / TABS ──
function switchTab(name, el) {
  document.querySelectorAll('.menu-section').forEach(s => s.classList.remove('active'));
  document.querySelectorAll('.tab').forEach(t => t.classList.remove('active'));
  document.getElementById('tab-'+name).classList.add('active');
  el.classList.add('active');
}

function showScreen(name, btn) {
  document.querySelectorAll('.screen').forEach(s => s.classList.remove('active'));
  document.querySelectorAll('.nav-btn').forEach(b => b.classList.remove('active'));
  document.getElementById('screen-'+name).classList.add('active');
  btn.classList.add('active');
  if (name === 'summary') renderSummary();
  if (name === 'admin' && document.getElementById('admin-content').style.display !== 'none') renderAdminTables();
}

function flash(msg) {
  const f = document.getElementById('flash');
  f.textContent = msg; f.classList.add('show');
  setTimeout(() => f.classList.remove('show'), 3000);
}

// ── CART REVIEW ──
function openReview() {
  if (!cart.length) return;
  renderReview();
  document.getElementById('review-overlay').classList.add('show');
}
function closeReview() {
  document.getElementById('review-overlay').classList.remove('show');
}
function closeReviewOutside(e) {
  if (e.target === document.getElementById('review-overlay')) closeReview();
}
function renderReview() {
  const body = document.getElementById('review-body');
  if (!cart.length) {
    body.innerHTML = '<div class="review-empty">No hay artículos en el pedido.</div>';
    document.getElementById('review-total').textContent = '0,00€';
    return;
  }
  body.innerHTML = cart.map((item,idx) => {
    const sub = (item.price*item.qty).toFixed(2).replace('.',',');
    return `<div class="review-item" style="flex-direction:column;align-items:stretch;gap:6px;">
      <div style="display:flex;align-items:center;gap:10px;">
        <div class="review-name">${item.name}</div>
        <div class="qty-ctrl">
          <button class="qty-btn" onclick="changeQty(${idx},-1)">−</button>
          <div class="qty-num">${item.qty}</div>
          <button class="qty-btn" onclick="changeQty(${idx},1)">+</button>
        </div>
        <div class="review-subtotal">${sub}€</div>
      </div>
      <textarea class="review-notes" rows="2" placeholder="Alergias o preferencias (opcional)..." oninput="setNote(${idx},this.value)">${item.notes||''}</textarea>
    </div>`;
  }).join('');
  const total = cart.reduce((s,i) => s+i.price*i.qty, 0);
  document.getElementById('review-total').textContent = total.toFixed(2).replace('.',',')+'€';
}
function setNote(idx, val) {
  if (cart[idx]) cart[idx].notes = val;
}

function changeQty(idx, delta) {
  cart[idx].qty += delta;
  if (cart[idx].qty <= 0) cart.splice(idx,1);
  updateCart();
  if (!cart.length) { closeReview(); return; }
  renderReview();
}
function confirmOrder() {
  closeReview();
  sendOrder();
}

// ── RESUMEN DE MESA ──
function renderSummary() {
  const {tbl} = getTable(TABLE_NUM);
  const container = document.getElementById('sum-items');
  const totalEl = document.getElementById('sum-grand-total');
  const billBtn = document.getElementById('bill-btn');
  const billBox = document.getElementById('bill-requested-box');

  // Merge all sent orders
  const merged = {};
  tbl.orders.forEach(order => {
    order.items.forEach(item => {
      if (!merged[item.name]) merged[item.name] = {name:item.name, price:item.price, qty:0, pending:false};
      merged[item.name].qty += item.qty;
    });
  });
  // Add pending cart items (not yet sent)
  cart.forEach(item => {
    const key = item.name+'__pending';
    if (!merged[key]) merged[key] = {name:item.name+' ⏳', price:item.price, qty:0, pending:true};
    merged[key].qty += item.qty;
  });

  const items = Object.values(merged);

  if (!items.length) {
    container.innerHTML = '<div class="sum-empty">Todavía no has pedido nada.<br>¡Explora la carta!</div>';
    totalEl.textContent = '0,00€';
    billBtn.style.display = 'none';
    billBox.style.display = 'none';
    return;
  }

  container.innerHTML = items.map(item => {
    const sub = (item.price*item.qty).toFixed(2).replace('.',',');
    const style = item.pending ? 'opacity:0.6' : '';
    return `<div class="sum-item" style="${style}">
      <div class="sum-item-name">${item.name}</div>
      <div class="sum-item-qty">${item.qty}×</div>
      <div class="sum-item-price">${sub}€</div>
    </div>`;
  }).join('');

  const grand = items.reduce((s,i) => s+i.price*i.qty, 0);
  totalEl.textContent = grand.toFixed(2).replace('.',',')+'€';

  if (tbl.billRequested) {
    billBtn.style.display = 'none';
    billBox.style.display = 'block';
    billBox.innerHTML = `✓ Cuenta solicitada a las <strong>${tbl.billRequestTime}</strong><br>El camarero viene enseguida 🙂`;
  } else if (tbl.orders.length > 0) {
    billBtn.style.display = 'block';
    billBox.style.display = 'none';
  } else {
    billBtn.style.display = 'none';
    billBox.style.display = 'none';
  }
}

function requestBill() {
  const {state, tbl} = getTable(TABLE_NUM);
  const t = new Date().toLocaleTimeString('es-ES', {hour:'2-digit', minute:'2-digit'});
  tbl.billRequested = true;
  tbl.billRequestTime = t;
  setState(state);
  renderSummary();
  flash('🧾 Cuenta solicitada — Mesa '+TABLE_NUM);
}

// ── ADMIN ──
function unlockAdmin() {
  const pin = document.getElementById('admin-pin').value;
  if (pin === ADMIN_PIN) {
    document.getElementById('admin-lock').style.display = 'none';
    document.getElementById('admin-content').style.display = 'block';
    renderAdminTables();
  } else {
    document.getElementById('admin-pin-error').style.display = 'block';
    document.getElementById('admin-pin').value = '';
  }
}

function switchAdminTab(name) {
  document.querySelectorAll('.admin-panel').forEach(p => p.classList.remove('active'));
  document.querySelectorAll('.admin-tab').forEach(t => t.classList.remove('active'));
  document.getElementById('apanel-'+name).classList.add('active');
  document.querySelector(`.admin-tab[data-tab="${name}"]`).classList.add('active');
  if (name === 'tables') renderAdminTables();
  if (name === 'stock') renderStockPanel();
  if (name === 'qr') renderAdminQR();
}

function renderAdminTables() {
  const s = getState();
  const alertsEl = document.getElementById('admin-bill-alerts');
  const grid = document.getElementById('admin-tables-grid');

  // Bill request alerts
  const alerts = Object.entries(s.tables || {}).filter(([_,t]) => t.billRequested);
  alertsEl.innerHTML = alerts.map(([num, t]) =>
    `<div class="bill-alert-banner">
      <div class="bab-text">🧾 Mesa ${num} solicita la cuenta · ${t.billRequestTime}</div>
      <button class="bab-dismiss" onclick="clearBillRequest('${num}')">✓ Atendido</button>
    </div>`
  ).join('');

  grid.innerHTML = TABLES.map(num => {
    const t = s.tables?.[num] || {orders:[], billRequested:false};
    const totalItems = t.orders.reduce((s,o) => s+o.items.reduce((ss,i) => ss+i.qty,0), 0);
    const grand = t.orders.reduce((s,o) => s+o.items.reduce((ss,i) => ss+i.price*i.qty,0), 0);
    const cls = t.billRequested ? 'bill-alert' : (totalItems>0 ? 'occupied' : '');
    return `<div class="table-card ${cls}" onclick="adminOpenTable(${num})">
      <div class="tc-num">Mesa ${num}</div>
      <div class="tc-status">${totalItems ? totalItems+(totalItems===1?' artículo':' artículos') : 'Libre'}</div>
      ${grand>0 ? `<div class="tc-total">${grand.toFixed(2).replace('.',',')}€</div>` : ''}
      ${t.billRequested ? `<div class="tc-bill">🧾 Solicita cuenta</div>` : ''}
    </div>`;
  }).join('');
}

function clearBillRequest(num) {
  const {state, tbl} = getTable(num);
  tbl.billRequested = false;
  tbl.billRequestTime = null;
  setState(state);
  renderAdminTables();
}

let currentAdminTable = null;
let adminCart = [];

function adminEnterMesa() {
  if (!currentAdminTable) return;
  const base = location.href.split('?')[0];
  window.open(`${base}?mesa=${currentAdminTable}`, '_blank');
}

function adminOpenTable(num) {
  currentAdminTable = num;
  adminCart = [];
  document.getElementById('admin-mesa-detail').style.display = 'block';
  document.getElementById('admin-mesa-title').textContent = `Mesa ${num}`;
  document.getElementById('admin-mesa-bill-btn').onclick = () => resetTable(num);
  switchAmdTab('pedido', document.querySelector('.amd-tab'));
  renderAdminOrder(num);
  document.getElementById('admin-mesa-detail').scrollIntoView({behavior:'smooth'});
}

function switchAmdTab(name, el) {
  document.querySelectorAll('.amd-tab').forEach(t => t.classList.remove('active'));
  document.querySelectorAll('.amd-panel').forEach(p => p.classList.remove('active'));
  el.classList.add('active');
  document.getElementById('amd-panel-'+name).classList.add('active');
  if (name === 'anadir') renderAmdMenu('');
}

function renderAdminOrder(num) {
  const {tbl} = getTable(num);
  const merged = {};
  tbl.orders.forEach(o => o.items.forEach(i => {
    if (!merged[i.name]) merged[i.name] = {name:i.name, price:i.price, qty:0};
    merged[i.name].qty += i.qty;
  }));
  const items = Object.values(merged);
  const grand = items.reduce((s,i) => s+i.price*i.qty, 0);
  document.getElementById('admin-mesa-total').textContent = grand.toFixed(2).replace('.',',')+'€';
  document.getElementById('admin-mesa-items').innerHTML = items.length
    ? items.map(i => `
      <div class="amd-order-item">
        <div class="amd-order-name">${i.name}</div>
        <div class="amd-qty-ctrl">
          <button class="amd-qty-btn" onclick="adminChangeQty('${i.name.replace(/'/g,"\\'")}',${i.price},-1,${num})">−</button>
          <div class="amd-qty-num">${i.qty}</div>
          <button class="amd-qty-btn" onclick="adminChangeQty('${i.name.replace(/'/g,"\\'")}',${i.price},1,${num})">+</button>
        </div>
        <div class="amd-order-price">${(i.price*i.qty).toFixed(2).replace('.',',')}€</div>
      </div>`).join('')
    : '<div class="amd-empty" style="padding:16px 14px;font-size:12px;color:rgba(255,255,255,0.25);">Sin pedidos aún</div>';
}

function adminChangeQty(name, price, delta, num) {
  const {state, tbl} = getTable(num);
  let remaining = delta < 0 ? 1 : 0;
  for (const o of tbl.orders) {
    for (let i = o.items.length-1; i >= 0; i--) {
      if (o.items[i].name === name) {
        o.items[i].qty += delta;
        if (o.items[i].qty <= 0) o.items.splice(i, 1);
        remaining = 0;
        break;
      }
    }
    if (!remaining) break;
  }
  tbl.orders = tbl.orders.filter(o => o.items.length > 0);
  setState(state);
  renderAdminOrder(num);
  renderAdminTables();
}

function renderAmdMenu(filter) {
  const items = getAllMenuItems();
  const filtered = filter ? items.filter(([n]) => n.toLowerCase().includes(filter.toLowerCase())) : items;
  document.getElementById('amd-menu-list').innerHTML = filtered.map(([name, price]) =>
    `<div class="amd-menu-item">
      <div class="amd-menu-name">${name}</div>
      <div class="amd-menu-price">${price.toFixed(2).replace('.',',')}€</div>
      <button class="amd-menu-add" onclick="adminAddToCart('${name.replace(/'/g,"\\'")}',${price})">+</button>
    </div>`
  ).join('') || '<div style="padding:12px;font-size:12px;color:rgba(255,255,255,0.25);">Sin resultados</div>';
  updateAmdCartBar();
  updateAmdCartBar();
}

function filterAmdMenu(val) { renderAmdMenu(val); }

function adminAddToCart(name, price) {
  const ex = adminCart.find(i => i.name === name);
  if (ex) ex.qty++; else adminCart.push({name, price, qty:1});
  updateAmdCartBar();
  flash(`➕ ${name}`);
}

function updateAmdCartBar() {
  const count = adminCart.reduce((s,i) => s+i.qty, 0);
  const total = adminCart.reduce((s,i) => s+i.price*i.qty, 0);
  document.getElementById('amd-cart-info').textContent = count
    ? `${count} artículo${count===1?'':'s'} · ${total.toFixed(2).replace('.',',')}€`
    : 'Sin artículos';
  document.getElementById('amd-send-btn').disabled = count === 0;
}

function sendAdminOrder() {
  if (!adminCart.length || !currentAdminTable) return;
  const now = new Date();
  const t = now.toLocaleTimeString('es-ES', {hour:'2-digit', minute:'2-digit'});
  const id = oid++;
  const tableLabel = `Mesa ${currentAdminTable} (Admin)`;
  const menuMap = Object.fromEntries(getAllMenuItems().map(([n,p,t]) => [n,t]));
  const food = adminCart.filter(i => menuMap[i.name] !== 'drink');
  const drink = adminCart.filter(i => menuMap[i.name] === 'drink');
  if (food.length) { kOrders.push({id, table:tableLabel, time:t, ts:Date.now(), items:food}); renderKDS('k'); }
  if (drink.length) { bOrders.push({id, table:tableLabel, time:t, ts:Date.now(), items:drink}); renderKDS('b'); }
  const {state, tbl} = getTable(currentAdminTable);
  tbl.orders.push({id, time:t, ts:Date.now(), items:[...adminCart]});
  setState(state);
  adminCart = [];
  updateAmdCartBar();
  renderAdminOrder(currentAdminTable);
  renderAdminTables();
  playOrderSound();
  flash(`🔔 Pedido admin enviado — Mesa ${currentAdminTable}`);
}

function resetTable(num) {
  if (!confirm(`¿Cerrar la sesión de Mesa ${num}?\nSe borrarán todos sus pedidos del resumen.`)) return;
  const {state} = getTable(num);
  delete state.tables[num];
  setState(state);
  renderAdminTables();
  document.getElementById('admin-mesa-detail').style.display = 'none';
}

function renderAdminQR() {
  const base = location.href.split('?')[0];
  const grid = document.getElementById('admin-qr-grid');
  const adminWrap = document.getElementById('admin-own-qr');

  // Admin QR
  const adminUrl = base+'?admin=1';
  adminWrap.innerHTML = buildQRCard(adminUrl, 'ADMIN · CAMARERO', true);

  // Table QRs
  grid.innerHTML = TABLES.map(num => {
    const url = base+'?mesa='+num;
    return buildQRCard(url, 'MESA '+num, false, num);
  }).join('');
}

function buildQRCard(url, label, isAdmin, tableNum) {
  const qrUrl = 'https://api.qrserver.com/v1/create-qr-code/?size=150x150&data='+encodeURIComponent(url);
  const extra = isAdmin ? ' admin-card' : '';
  const printArg = isAdmin ? "'admin'" : tableNum;
  return `<div class="qr-card${extra}">
    <img src="${qrUrl}" alt="QR ${label}" loading="lazy">
    <div class="qr-label">${label}</div>
    <button class="qr-print-btn" onclick="printQR(${printArg})">🖨️ Imprimir</button>
  </div>`;
}

function printQR(tableNum) {
  const base = location.href.split('?')[0];
  const isAdmin = tableNum === 'admin';
  const url = isAdmin ? base+'?admin=1' : base+'?mesa='+tableNum;
  const label = isAdmin ? 'ADMIN · CAMARERO' : 'MESA '+tableNum;
  const qrUrl = 'https://api.qrserver.com/v1/create-qr-code/?size=220x220&data='+encodeURIComponent(url);
  const win = window.open('','_blank','width=320,height=440');
  win.document.write(`<!DOCTYPE html><html><head><meta charset="UTF-8"><title>QR ${label}</title>
  <style>*{margin:0;padding:0;box-sizing:border-box;}body{font-family:'Courier New',monospace;width:280px;padding:20px;text-align:center;}
  h2{font-size:16px;font-weight:700;margin-bottom:3px;}p{font-size:10px;color:#666;margin-bottom:14px;}
  img{width:220px;height:220px;border:2px solid #000;display:block;margin:0 auto;}
  .mesa{font-size:22px;font-weight:700;margin-top:14px;border:3px solid #000;padding:8px;letter-spacing:0.05em;}
  .foot{font-size:9px;color:#aaa;margin-top:10px;word-break:break-all;}
  @media print{body{-webkit-print-color-adjust:exact;}}</style>
  </head><body>
  <h2>${NOMBRE_RESTAURANTE}</h2>
  <p>Escanea para ver la carta y pedir</p>
  <img src="${qrUrl}" alt="QR">
  <div class="mesa">${label}</div>
  <div class="foot">${url}</div>
  </body></html>`);
  win.document.close();
  win.focus();
  setTimeout(() => { win.print(); win.close(); }, 800);
}

// ── TICKET ──
let currentTicketHTML = '';

function showTicket(s, idx) {
  const order = s==='k' ? kOrders[idx] : bOrders[idx];
  if (!order) return;
  const station = s==='k'?'COCINA':'BARRA';
  const stationIcon = s==='k'?'🔥':'🍷';
  const now = new Date().toLocaleTimeString('es-ES', {hour:'2-digit', minute:'2-digit', second:'2-digit'});
  const total = order.items.reduce((sum,i) => sum+i.price*i.qty, 0);
  const itemRows = order.items.map(i => {
    const sub = (i.price*i.qty).toFixed(2).replace('.',',');
    return `<div class="tk-item-row"><span class="tk-qty">${i.qty}x</span><span class="tk-item-name">${i.name}</span><span style="text-align:right;min-width:45px">${sub}€</span></div>`;
  }).join('');
  currentTicketHTML = `
    <div class="tk-logo">${NOMBRE_RESTAURANTE}</div>
    <div class="tk-sub">Restaurante & Bar</div>
    <div class="tk-addr">${DIRECCION} <br>${TELEFONO}</div>
    <div class="tk-div2"></div>
    <div class="tk-station">${stationIcon} ${station}</div>
    <div class="tk-meta">Pedido: <span>#${order.id}</span></div>
    <div class="tk-meta">Mesa: <span>${order.table}</span></div>
    <div class="tk-meta">Hora pedido: <span>${order.time}</span></div>
    <div class="tk-meta">Impresión: <span>${now}</span></div>
    <div class="tk-div"></div>
    ${itemRows}
    <div class="tk-div"></div>
    <div class="tk-total-row"><span>TOTAL</span><span>${total.toFixed(2).replace('.',',')}€</span></div>
    <div class="tk-div2"></div>
    <div class="tk-footer">Gracias por elegir ${NOMBRE_RESTAURANTE}<br>${ESLOGAN_RESTAURANTE}</div>
    <div style="height:16px"></div>`;
  document.getElementById('ticket-content').innerHTML = currentTicketHTML;
  document.getElementById('ticket-overlay').classList.add('show');
}

function printTicket() {
  const win = window.open('','_blank','width=320,height=600');
  win.document.write(`<!DOCTYPE html><html><head><meta charset="UTF-8"><title>Comanda ${NOMBRE_RESTAURANTE}</title>
  <style>*{margin:0;padding:0;box-sizing:border-box;}body{font-family:'Courier New',monospace;font-size:12px;width:302px;padding:10px;}
  .tk-logo{text-align:center;font-size:18px;font-weight:700;}.tk-sub{text-align:center;font-size:10px;color:#555;}.tk-addr{text-align:center;font-size:9px;color:#777;margin-bottom:8px;}
  .tk-div{border-top:1px dashed #aaa;margin:5px 0;}.tk-div2{border-top:2px solid #000;margin:5px 0;}
  .tk-station{text-align:center;font-weight:700;font-size:13px;border:2px solid #000;padding:4px;margin-bottom:8px;letter-spacing:0.1em;}
  .tk-meta{font-size:11px;margin-bottom:2px;display:flex;justify-content:space-between;}
  .tk-item-row{display:flex;margin:3px 0;font-size:11px;}.tk-qty{width:28px;font-weight:700;}.tk-item-name{flex:1;}
  .tk-total-row{display:flex;justify-content:space-between;font-weight:700;font-size:13px;margin-top:4px;}
  .tk-footer{text-align:center;font-size:9px;color:#888;margin-top:8px;}</style>
  </head><body>${currentTicketHTML}</body></html>`);
  win.document.close(); win.focus();
  setTimeout(() => { win.print(); win.close(); }, 400);
}

function closeTicket(e) {
  if (e.target === document.getElementById('ticket-overlay'))
    document.getElementById('ticket-overlay').classList.remove('show');
}
</script>


