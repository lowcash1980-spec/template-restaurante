<!DOCTYPE html>

<html lang="es"><head><meta http-equiv="Content-Type" content="text/html; charset=UTF-8">

<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>${NOMBRE_RESTAURANTE} — Carta Digital</title>
<link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,400;0,600;0,700;1,400&family=DM+Sans:wght@400;500;600&display=swap" rel="stylesheet">
<style>
:root {
  --cream:#fdf8f2; --warm:#f5ede0; --terra:#b5541e; --terra2:#8a3a10;
  --gold:#c9913a; --gold-lt:#e4b86a; --text:#2a1f14; --muted:#8a7060;
  --border:#dfd0bc; --white:#ffffff;
  --k-bg:#0f0a06; --k-card:#1c1208; --k-bord:#2e1e0a;
  --b-bg:#060e18; --b-card:#0c1a2e; --b-bord:#12273a;
}
*{margin:0;padding:0;box-sizing:border-box;}
body{font-family:'DM Sans',sans-serif;background:#1a1008;min-height:100vh;}

/* NAV */
.nav{position:fixed;top:0;left:0;right:0;z-index:999;background:#0d0804;border-bottom:1px solid #2a1a08;display:flex;align-items:center;padding:9px 14px;gap:7px;overflow-x:auto;}
.nav-label{font-size:9px;color:#5a3a1a;text-transform:uppercase;letter-spacing:0.2em;white-space:nowrap;margin-right:2px;}
.nav-btn{font-family:'DM Sans',sans-serif;font-size:11px;font-weight:600;padding:6px 13px;border:1px solid #3a2010;background:transparent;color:#7a5030;cursor:pointer;transition:all 0.2s;white-space:nowrap;border-radius:2px;}
.nav-btn.active{background:var(--terra);border-color:var(--terra);color:#fff;}
.nav-btn:hover:not(.active){border-color:var(--gold);color:var(--gold);}

.screen{display:none;padding-top:52px;min-height:100vh;}
.screen.active{display:block;}

/* CUSTOMER */
#screen-customer{background:var(--cream);}
.hero{background:linear-gradient(170deg,#1a0c04 0%,#3a1a08 50%,#5a2e10 100%);padding:28px 20px 22px;text-align:center;position:relative;overflow:hidden;}
.hero::before{content:'';position:absolute;inset:0;background:radial-gradient(ellipse at 50% -10%,rgba(201,145,58,0.25) 0%,transparent 65%);}
.hero::after{content:'';position:absolute;bottom:0;left:0;right:0;height:1px;background:linear-gradient(90deg,transparent,var(--gold),transparent);}
.hero-sub{font-size:9px;letter-spacing:0.3em;text-transform:uppercase;color:var(--gold-lt);margin-bottom:10px;position:relative;}
.hero-name{font-family:'Cormorant Garamond',serif;font-size:44px;font-weight:700;color:#fff;line-height:1;position:relative;margin-bottom:4px;}
.hero-name em{font-style:italic;color:var(--gold-lt);}
.hero-tagline{font-size:11px;color:rgba(255,255,255,0.45);position:relative;margin-bottom:12px;}
.hero-chef{font-size:10px;color:rgba(255,255,255,0.3);position:relative;font-style:italic;margin-bottom:12px;}
.table-pill{display:inline-block;position:relative;border:1px solid rgba(201,145,58,0.5);padding:5px 16px;font-size:11px;color:var(--gold-lt);letter-spacing:0.12em;}
.name-input-wrap{margin-top:12px;position:relative;}
.name-input{background:rgba(255,255,255,0.07);border:1px solid rgba(201,145,58,0.35);color:#fff;font-family:'DM Sans',sans-serif;font-size:12px;padding:7px 14px;text-align:center;width:180px;border-radius:2px;outline:none;letter-spacing:0.04em;}
.name-input::placeholder{color:rgba(255,255,255,0.25);}
.name-input:focus{border-color:rgba(201,145,58,0.7);background:rgba(255,255,255,0.1);}
.name-label{font-size:9px;color:rgba(255,255,255,0.25);letter-spacing:0.15em;text-transform:uppercase;margin-bottom:5px;}

/* TABS */
.tabs{display:flex;background:var(--terra2);overflow-x:auto;position:sticky;top:52px;z-index:10;border-bottom:1px solid rgba(0,0,0,0.15);}
.tab{flex:1;min-width:64px;padding:10px 6px;text-align:center;font-size:10px;font-weight:600;color:rgba(255,255,255,0.4);cursor:pointer;transition:all 0.2s;border-bottom:2px solid transparent;white-space:nowrap;}
.tab.active{color:#fff;border-bottom-color:var(--gold-lt);}

.menu-section{display:none;padding-bottom:110px;}
.menu-section.active{display:block;}

.sec-head{display:flex;align-items:center;gap:10px;padding:14px 16px 10px;margin-top:4px;}
.sec-head-line{flex:1;height:1px;background:#e0cbb4;}
.sec-head-text{font-family:'Cormorant Garamond',serif;font-size:11px;font-weight:600;text-transform:uppercase;letter-spacing:0.2em;color:var(--muted);white-space:nowrap;}

/* MENU ITEM */
.item{display:flex;gap:10px;align-items:flex-start;padding:12px 14px;border-bottom:1px solid var(--border);background:var(--white);transition:background 0.15s;}
.item:hover{background:var(--warm);}
.item-body{flex:1;min-width:0;}
.item-name{font-size:13px;font-weight:600;color:var(--text);margin-bottom:2px;line-height:1.35;}
.item-desc{font-size:10.5px;color:var(--muted);line-height:1.45;}
.item-badge{display:inline-block;margin-top:3px;font-size:8.5px;letter-spacing:0.1em;padding:1px 6px;border:1px solid var(--gold);color:var(--gold);text-transform:uppercase;}
.item-right{display:flex;flex-direction:column;align-items:flex-end;gap:6px;flex-shrink:0;min-width:52px;}
.price{font-family:'Cormorant Garamond',serif;font-size:16px;font-weight:600;color:var(--terra);white-space:nowrap;}
.price-sub{font-size:9px;color:var(--muted);text-align:right;line-height:1.3;}
.add{width:28px;height:28px;border-radius:50%;border:none;background:var(--terra);color:#fff;font-size:20px;font-weight:300;display:flex;align-items:center;justify-content:center;cursor:pointer;transition:all 0.15s;line-height:1;flex-shrink:0;}
.add:hover{background:var(--gold);transform:scale(1.1);}
.add:active{transform:scale(0.92);}
/* DUAL OPTION BUTTONS */
.dual-btns{display:flex;flex-direction:column;gap:5px;align-items:flex-end;}
.dual-btn{display:flex;align-items:center;gap:6px;background:var(--warm);border:1px solid var(--border);padding:4px 8px 4px 10px;cursor:pointer;transition:all 0.15s;border-radius:2px;}
.dual-btn:hover{background:var(--terra);border-color:var(--terra);}
.dual-btn:hover .dual-label{color:#fff;}
.dual-btn:hover .dual-price{color:#fff;}
.dual-btn:active{transform:scale(0.96);}
.dual-label{font-size:9px;font-weight:700;text-transform:uppercase;letter-spacing:0.08em;color:var(--muted);}
.dual-price{font-family:'Cormorant Garamond',serif;font-size:14px;font-weight:600;color:var(--terra);}
.dual-add{width:20px;height:20px;border-radius:50%;background:var(--terra);color:#fff;font-size:14px;font-weight:300;display:flex;align-items:center;justify-content:center;flex-shrink:0;line-height:1;}
.dual-btn:hover .dual-add{background:#fff;color:var(--terra);}

/* CART */
.cart{position:fixed;bottom:0;left:0;right:0;z-index:100;background:var(--terra2);padding:13px 20px;display:flex;align-items:center;justify-content:space-between;transform:translateY(100%);transition:transform 0.3s cubic-bezier(0.4,0,0.2,1);box-shadow:0 -6px 30px rgba(0,0,0,0.35);}
.cart.show{transform:translateY(0);}
.cart-left{color:#fff;}
.cart-n{font-size:11px;color:rgba(255,255,255,0.6);margin-bottom:2px;}
.cart-t{font-family:'Cormorant Garamond',serif;font-size:20px;font-weight:600;}
.send-btn{background:var(--gold);color:#1a0c04;border:none;font-family:'DM Sans',sans-serif;font-weight:700;font-size:12px;padding:11px 20px;cursor:pointer;letter-spacing:0.06em;border-radius:2px;transition:background 0.2s;}
.send-btn:hover{background:var(--gold-lt);}

/* ORDER MODAL */
.overlay{position:fixed;inset:0;z-index:200;background:rgba(30,10,0,0.8);display:flex;align-items:center;justify-content:center;opacity:0;pointer-events:none;transition:opacity 0.3s;}
.overlay.show{opacity:1;pointer-events:all;}
.modal{background:var(--white);padding:32px 26px;text-align:center;max-width:290px;width:90%;transform:scale(0.9);transition:transform 0.3s;}
.overlay.show .modal{transform:scale(1);}
.modal-ico{font-size:48px;margin-bottom:10px;}
.modal-ttl{font-family:'Cormorant Garamond',serif;font-size:24px;color:var(--text);margin-bottom:8px;}
.modal-txt{font-size:12px;color:var(--muted);line-height:1.6;margin-bottom:20px;white-space:pre-line;}
.modal-btn{background:var(--terra);color:#fff;border:none;padding:10px 28px;font-family:'DM Sans',sans-serif;font-weight:600;font-size:12px;cursor:pointer;border-radius:2px;}

/* CART REVIEW MODAL */
.review-overlay{position:fixed;inset:0;z-index:250;background:rgba(20,8,0,0.85);display:flex;align-items:flex-end;justify-content:center;opacity:0;pointer-events:none;transition:opacity 0.3s;}
.review-overlay.show{opacity:1;pointer-events:all;}
.review-sheet{background:var(--white);width:100%;max-width:480px;max-height:88vh;display:flex;flex-direction:column;transform:translateY(100%);transition:transform 0.35s cubic-bezier(0.16,1,0.3,1);}
.review-overlay.show .review-sheet{transform:translateY(0);}
.review-header{display:flex;align-items:center;justify-content:space-between;padding:16px 18px 12px;border-bottom:2px solid var(--terra);}
.review-title{font-family:'Cormorant Garamond',serif;font-size:22px;font-weight:700;color:var(--text);}
.review-close{background:none;border:none;font-size:22px;color:var(--muted);cursor:pointer;padding:0 4px;line-height:1;}
.review-body{overflow-y:auto;flex:1;padding:0 0 8px;}
.review-item{display:flex;align-items:center;gap:10px;padding:12px 18px;border-bottom:1px solid var(--border);}
.review-name{flex:1;font-size:13px;font-weight:500;color:var(--text);line-height:1.3;}
.review-subtotal{font-family:'Cormorant Garamond',serif;font-size:14px;font-weight:600;color:var(--terra);min-width:52px;text-align:right;}
.qty-ctrl{display:flex;align-items:center;gap:0;border:1px solid var(--border);border-radius:3px;overflow:hidden;flex-shrink:0;}
.qty-btn{width:28px;height:28px;border:none;background:var(--warm);color:var(--brown);font-size:16px;font-weight:600;cursor:pointer;display:flex;align-items:center;justify-content:center;transition:background 0.15s;line-height:1;}
.qty-btn:hover{background:var(--terra);color:#fff;}
.qty-num{width:28px;text-align:center;font-size:13px;font-weight:700;color:var(--brown);background:var(--white);}
.review-footer{padding:14px 18px;border-top:2px solid var(--border);background:var(--cream);}
.review-total-row{display:flex;justify-content:space-between;align-items:baseline;margin-bottom:14px;}
.review-total-label{font-size:13px;color:var(--muted);text-transform:uppercase;letter-spacing:0.1em;}
.review-total-price{font-family:'Cormorant Garamond',serif;font-size:26px;font-weight:700;color:var(--terra);}
.confirm-btn{width:100%;padding:14px;background:var(--terra);color:#fff;border:none;font-family:'DM Sans',sans-serif;font-weight:700;font-size:14px;letter-spacing:0.06em;cursor:pointer;border-radius:2px;transition:background 0.2s;}
.confirm-btn:hover{background:var(--gold);}
.review-empty{padding:32px;text-align:center;font-size:13px;color:var(--muted);font-style:italic;}

/* KDS */
#screen-kitchen{background:var(--k-bg);}
#screen-bar{background:var(--b-bg);}
.kds-top{display:flex;align-items:center;justify-content:space-between;padding:16px 20px 12px;border-bottom:1px solid rgba(255,255,255,0.07);}
.kds-title{font-family:'Cormorant Garamond',serif;font-size:24px;font-weight:700;}
#screen-kitchen .kds-title{color:#ff7040;}
#screen-bar .kds-title{color:#40c0f0;}
.kds-rest{font-size:9px;letter-spacing:0.2em;text-transform:uppercase;margin-top:2px;opacity:0.3;color:#fff;}
.kds-clock{font-size:20px;font-weight:600;color:rgba(255,255,255,0.55);font-variant-numeric:tabular-nums;}
.kds-empty{padding:70px 20px;text-align:center;}
.kds-empty-ico{font-size:50px;margin-bottom:10px;opacity:0.25;}
.kds-empty-msg{font-size:13px;color:rgba(255,255,255,0.2);line-height:1.6;}
.grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(230px,1fr));gap:12px;padding:14px;}
.ocard{border-radius:3px;overflow:hidden;animation:pop 0.4s cubic-bezier(0.16,1,0.3,1);}
#screen-kitchen .ocard{background:var(--k-card);border:1px solid var(--k-bord);}
#screen-bar .ocard{background:var(--b-card);border:1px solid var(--b-bord);}
@keyframes pop{from{opacity:0;transform:scale(0.94) translateY(-10px)}to{opacity:1;transform:none}}
.ocard-head{display:flex;align-items:center;justify-content:space-between;padding:10px 14px;}
#screen-kitchen .ocard-head{background:#2e0e06;border-bottom:1px solid #3e1a0a;}
#screen-bar .ocard-head{background:#061428;border-bottom:1px solid #0e2040;}
.o-table{font-size:14px;font-weight:700;color:#fff;}
.o-time{font-size:10px;color:rgba(255,255,255,0.35);margin-top:1px;}
.o-elapsed{font-size:12px;font-weight:700;padding:3px 8px;border-radius:2px;font-variant-numeric:tabular-nums;}
.ok{background:rgba(50,200,80,0.15);color:#4ade80;}
.warn{background:rgba(250,180,0,0.15);color:#fbbf24;}
.late{background:rgba(220,40,40,0.15);color:#f87171;}
.ocard-items{padding:10px 14px;}
.oi{display:flex;gap:8px;padding:4px 0;border-bottom:1px solid rgba(255,255,255,0.05);}
.oi:last-child{border:none;}
.oi-q{font-size:13px;font-weight:700;color:var(--gold);min-width:20px;}
.oi-n{font-size:12px;color:rgba(255,255,255,0.85);flex:1;line-height:1.3;}
.card-actions{display:flex;gap:0;}
.done-btn{flex:1;padding:10px;border:none;font-family:'DM Sans',sans-serif;font-weight:700;font-size:11px;cursor:pointer;letter-spacing:0.08em;transition:background 0.2s;}
#screen-kitchen .done-btn{background:#b5421e;color:#fff;}
#screen-kitchen .done-btn:hover{background:#d4541e;}
#screen-bar .done-btn{background:#0d4a8a;color:#fff;}
#screen-bar .done-btn:hover{background:#1060aa;}
.print-btn{padding:10px 14px;border:none;border-left:1px solid rgba(255,255,255,0.1);font-size:16px;cursor:pointer;transition:background 0.2s;flex-shrink:0;}
#screen-kitchen .print-btn{background:#8a3010;color:#fff;}
#screen-kitchen .print-btn:hover{background:#b5421e;}
#screen-bar .print-btn{background:#063060;color:#fff;}
#screen-bar .print-btn:hover{background:#0d4a8a;}

/* FLASH */
.flash{position:fixed;top:58px;left:50%;transform:translateX(-50%) translateY(-14px);background:var(--terra);color:#fff;padding:9px 18px;font-weight:700;font-size:12px;opacity:0;transition:all 0.3s;z-index:500;border-radius:2px;pointer-events:none;white-space:nowrap;}
.flash.show{opacity:1;transform:translateX(-50%) translateY(0);}

/* TICKET MODAL */
.ticket-overlay{position:fixed;inset:0;z-index:300;background:rgba(0,0,0,0.85);display:flex;align-items:center;justify-content:center;opacity:0;pointer-events:none;transition:opacity 0.25s;}
.ticket-overlay.show{opacity:1;pointer-events:all;}
.ticket-wrap{background:#fff;width:302px;box-shadow:0 20px 60px rgba(0,0,0,0.5);transform:scale(0.9);transition:transform 0.25s;}
.ticket-overlay.show .ticket-wrap{transform:scale(1);}
.ticket-actions{display:flex;gap:0;background:#1a1208;}
.t-btn{flex:1;padding:11px;border:none;font-family:'DM Sans',sans-serif;font-weight:700;font-size:11px;cursor:pointer;letter-spacing:0.06em;transition:background 0.2s;}
.t-btn-print{background:#c9913a;color:#120800;}
.t-btn-print:hover{background:#e4b86a;}
.t-btn-close{background:#333;color:#aaa;}
.t-btn-close:hover{background:#444;}
#ticket-content{font-family:'Courier New',Courier,monospace;font-size:12px;line-height:1.5;color:#000;padding:14px 10px;background:#fff;width:282px;}
.tk-logo{text-align:center;font-size:18px;font-weight:700;letter-spacing:0.05em;margin-bottom:2px;}
.tk-sub{text-align:center;font-size:10px;color:#555;margin-bottom:2px;}
.tk-addr{text-align:center;font-size:9px;color:#777;margin-bottom:8px;}
.tk-div{border-top:1px dashed #aaa;margin:6px 0;}
.tk-div2{border-top:2px solid #000;margin:6px 0;}
.tk-station{text-align:center;font-weight:700;font-size:13px;padding:4px 0;letter-spacing:0.1em;border:2px solid #000;margin-bottom:8px;}
.tk-meta{font-size:11px;margin-bottom:2px;}
.tk-meta span{float:right;}
.tk-item-row{display:flex;margin:3px 0;font-size:11px;}
.tk-qty{width:28px;font-weight:700;flex-shrink:0;}
.tk-item-name{flex:1;}
.tk-total-row{display:flex;justify-content:space-between;font-weight:700;font-size:13px;margin-top:6px;}
.tk-footer{text-align:center;font-size:9px;color:#888;margin-top:8px;}

/* SUMMARY SCREEN */
#screen-summary{background:var(--cream);}
.sum-hero{background:linear-gradient(170deg,#1a0c04 0%,#3a1a08 50%,#5a2e10 100%);padding:20px;text-align:center;position:relative;}
.sum-hero::after{content:'';position:absolute;bottom:0;left:0;right:0;height:1px;background:linear-gradient(90deg,transparent,var(--gold),transparent);}
.sum-title{font-family:'Cormorant Garamond',serif;font-size:26px;font-weight:700;color:#fff;}
.sum-mesa{font-size:11px;color:var(--gold-lt);margin-top:4px;letter-spacing:0.1em;}
.sum-item{display:flex;align-items:center;gap:10px;padding:11px 16px;border-bottom:1px solid var(--border);background:var(--white);}
.sum-item-name{font-size:13px;color:var(--text);flex:1;line-height:1.3;}
.sum-item-qty{font-size:11px;font-weight:700;color:var(--terra);min-width:28px;text-align:center;}
.sum-item-price{font-family:'Cormorant Garamond',serif;font-size:15px;color:var(--terra);min-width:58px;text-align:right;}
.sum-total-bar{display:flex;justify-content:space-between;align-items:baseline;padding:14px 18px;border-top:2px solid var(--border);background:var(--cream);}
.sum-total-label{font-size:11px;color:var(--muted);text-transform:uppercase;letter-spacing:0.12em;}
.sum-total-amount{font-family:'Cormorant Garamond',serif;font-size:28px;font-weight:700;color:var(--terra);}
.bill-btn{width:calc(100% - 32px);margin:12px 16px 6px;padding:15px;background:var(--terra);color:#fff;border:none;font-family:'DM Sans',sans-serif;font-weight:700;font-size:14px;letter-spacing:0.08em;cursor:pointer;border-radius:2px;transition:background 0.2s;}
.bill-btn:hover{background:var(--terra2);}
.bill-requested-box{margin:12px 16px;padding:14px 16px;background:rgba(181,84,30,0.08);border:1px solid var(--terra);color:var(--terra);text-align:center;font-size:13px;font-weight:600;border-radius:2px;line-height:1.5;}
.sum-empty{padding:52px 20px;text-align:center;font-size:13px;color:var(--muted);font-style:italic;}
.sum-section-label{padding:10px 16px 4px;font-size:9px;color:var(--muted);text-transform:uppercase;letter-spacing:0.2em;}

/* ADMIN SCREEN */
#screen-admin{background:#0a0604;min-height:100vh;padding-bottom:40px;}
.admin-top{padding:16px 20px 12px;border-bottom:1px solid rgba(255,255,255,0.07);display:flex;align-items:center;justify-content:space-between;}
.admin-title{font-family:'Cormorant Garamond',serif;font-size:24px;font-weight:700;color:#e4b86a;}
.admin-sub{font-size:9px;letter-spacing:0.2em;text-transform:uppercase;color:rgba(255,255,255,0.25);margin-top:2px;}
.admin-tabs{display:flex;background:#1a0c04;border-bottom:1px solid #2a1a08;}
.admin-tab{flex:1;padding:10px;text-align:center;font-size:11px;font-weight:600;color:rgba(255,255,255,0.35);cursor:pointer;border-bottom:2px solid transparent;transition:all 0.2s;}
.admin-tab.active{color:#e4b86a;border-bottom-color:#e4b86a;}
.admin-panel{display:none;padding:14px;}
.admin-panel.active{display:block;}
.admin-lock{padding:40px 20px;text-align:center;}
.admin-lock h3{font-family:'Cormorant Garamond',serif;font-size:22px;color:#e4b86a;margin-bottom:8px;}
.admin-lock p{font-size:12px;color:rgba(255,255,255,0.4);margin-bottom:20px;}
.admin-pin-input{width:160px;padding:12px;text-align:center;font-size:20px;letter-spacing:0.3em;background:#1c1208;color:#e4b86a;border:1px solid #2e1e0a;border-radius:2px;font-family:'DM Sans',sans-serif;}
.admin-pin-btn{margin-top:12px;display:block;width:160px;margin-left:auto;margin-right:auto;padding:12px;background:#c9913a;color:#0a0604;border:none;font-weight:700;font-size:13px;cursor:pointer;border-radius:2px;}
.admin-pin-error{color:#f87171;font-size:12px;margin-top:8px;display:none;}
.table-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(130px,1fr));gap:10px;}
.table-card{background:#1c1208;border:1px solid #2e1e0a;border-radius:3px;padding:12px;cursor:pointer;transition:border-color 0.2s;}
.table-card:hover{border-color:#c9913a;}
.table-card.bill-alert{border-color:#f87171;animation:pulse-red 1.5s infinite;}
.table-card.occupied{border-color:#3a2810;}
@keyframes pulse-red{0%,100%{border-color:#f87171}50%{border-color:#ff9999}}
.tc-num{font-family:'Cormorant Garamond',serif;font-size:20px;font-weight:700;color:#e4b86a;}
.tc-status{font-size:10px;color:rgba(255,255,255,0.3);margin-top:2px;}
.tc-total{font-size:11px;font-weight:700;color:#c9913a;margin-top:3px;}
.tc-bill{font-size:10px;color:#f87171;margin-top:3px;font-weight:700;}
.bill-alert-banner{background:#7a1a10;color:#fff;padding:10px 14px;display:flex;align-items:center;justify-content:space-between;margin-bottom:8px;border-radius:2px;}
.bab-text{font-size:12px;font-weight:700;}
.bab-dismiss{background:rgba(255,255,255,0.15);border:none;color:#fff;padding:5px 10px;font-size:11px;cursor:pointer;border-radius:2px;font-weight:700;}
.admin-mesa-detail{background:#1c1208;border:1px solid #c9913a;border-radius:3px;margin-top:14px;overflow:hidden;}
.amd-head{display:flex;align-items:center;justify-content:space-between;padding:10px 14px;background:#2e1e0a;}
.amd-title{font-size:15px;font-weight:700;color:#e4b86a;}
.amd-total{font-family:'Cormorant Garamond',serif;font-size:17px;color:#e4b86a;}
.amd-items{padding:10px 14px;}
.amd-item{display:flex;justify-content:space-between;padding:5px 0;border-bottom:1px solid rgba(255,255,255,0.05);font-size:12px;color:rgba(255,255,255,0.75);}
.amd-item:last-child{border:none;}
.amd-actions{display:flex;gap:8px;padding:10px 14px 12px;}
.amd-btn{flex:1;padding:9px;border:none;font-size:11px;font-weight:700;cursor:pointer;border-radius:2px;}
.amd-btn-reset{background:#7a1a10;color:#fff;}
.amd-btn-reset:hover{background:#b5241e;}
.amd-empty{padding:16px 14px;font-size:12px;color:rgba(255,255,255,0.25);font-style:italic;}
.qr-intro{font-size:12px;color:rgba(255,255,255,0.35);margin-bottom:14px;}
.qr-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(155px,1fr));gap:12px;}
.qr-card{background:#1c1208;border:1px solid #2e1e0a;border-radius:3px;padding:14px;text-align:center;}
.qr-card.admin-card{border-color:#c9913a;background:#2a1a04;}
.qr-card img{width:130px;height:130px;border:3px solid #fff;border-radius:2px;display:block;margin:0 auto;}
.qr-label{font-size:13px;font-weight:700;color:#e4b86a;margin-top:8px;}
.qr-print-btn{margin-top:8px;width:100%;padding:7px;background:#c9913a;color:#0a0604;border:none;font-weight:700;font-size:10px;cursor:pointer;border-radius:2px;transition:background 0.2s;letter-spacing:0.06em;}
.qr-print-btn:hover{background:#e4b86a;}
.qr-admin-wrap{margin-bottom:16px;}
.qr-admin-label{font-size:10px;color:#c9913a;text-transform:uppercase;letter-spacing:0.2em;margin-bottom:8px;}

/* AGOTADO */
.item.agotado-item .add,.dual-btn.agotado-btn{opacity:0.35;cursor:not-allowed;pointer-events:none;}
.agotado-badge{display:inline-block;margin-top:3px;font-size:8.5px;letter-spacing:0.1em;padding:1px 7px;border:1px solid #c0392b;color:#c0392b;text-transform:uppercase;background:rgba(192,57,43,0.07);}
.stock-row{display:flex;align-items:center;justify-content:space-between;padding:9px 12px;border-bottom:1px solid rgba(255,255,255,0.05);font-size:12px;color:rgba(255,255,255,0.75);}
.stock-row:last-child{border:none;}
.stock-name{flex:1;padding-right:10px;line-height:1.3;}
.stock-toggle{position:relative;width:40px;height:22px;flex-shrink:0;}
.stock-toggle input{opacity:0;width:0;height:0;}
.stock-slider{position:absolute;cursor:pointer;inset:0;background:#2e1e0a;border-radius:22px;transition:0.2s;}
.stock-slider::before{content:'';position:absolute;height:16px;width:16px;left:3px;bottom:3px;background:#5a3a1a;border-radius:50%;transition:0.2s;}
.stock-toggle input:checked+.stock-slider{background:#3a7a2a;}
.stock-toggle input:checked+.stock-slider::before{transform:translateX(18px);background:#fff;}
.stock-search{width:100%;padding:9px 12px;background:#1c1208;color:#fff;border:1px solid #2e1e0a;font-family:'DM Sans',sans-serif;font-size:12px;border-radius:2px;margin-bottom:10px;}
.stock-search::placeholder{color:rgba(255,255,255,0.25);}
.stock-list{background:#1c1208;border:1px solid #2e1e0a;border-radius:3px;max-height:60vh;overflow-y:auto;}
.stock-agotado-count{font-size:10px;color:#f87171;margin-bottom:8px;}

/* NOTAS EN REVIEW */
.review-notes{width:100%;margin-top:6px;padding:6px 8px;font-size:11px;font-family:'DM Sans',sans-serif;border:1px solid var(--border);border-radius:2px;color:var(--text);background:var(--cream);resize:none;line-height:1.4;}
.review-notes::placeholder{color:var(--muted);}
.oi-notes{font-size:10px;color:rgba(255,255,255,0.45);font-style:italic;margin-top:2px;padding-left:28px;}

/* ADMIN MESA DETAIL MEJORADO */
.amd-tabs{display:flex;border-bottom:1px solid rgba(255,255,255,0.07);margin-bottom:10px;}
.amd-tab{flex:1;padding:8px;text-align:center;font-size:11px;font-weight:600;color:rgba(255,255,255,0.3);cursor:pointer;border-bottom:2px solid transparent;transition:all 0.2s;}
.amd-tab.active{color:#e4b86a;border-bottom-color:#e4b86a;}
