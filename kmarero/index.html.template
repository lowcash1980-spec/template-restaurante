.amd-qty-ctrl{display:flex;align-items:center;gap:0;border:1px solid rgba(255,255,255,0.1);border-radius:2px;overflow:hidden;flex-shrink:0;}
.amd-qty-btn{width:26px;height:26px;border:none;background:rgba(255,255,255,0.05);color:rgba(255,255,255,0.6);font-size:15px;cursor:pointer;display:flex;align-items:center;justify-content:center;transition:background 0.15s;}
.amd-qty-btn:hover{background:#b5421e;color:#fff;}
.amd-qty-num{width:26px;text-align:center;font-size:12px;font-weight:700;color:#fff;background:rgba(255,255,255,0.04);}
.amd-add-search{width:100%;padding:8px 12px;background:#0f0804;color:#fff;border:1px solid #2e1e0a;font-family:'DM Sans',sans-serif;font-size:12px;border-radius:2px;margin-bottom:8px;}
.amd-add-search::placeholder{color:rgba(255,255,255,0.2);}
.amd-menu-list{max-height:40vh;overflow-y:auto;}
