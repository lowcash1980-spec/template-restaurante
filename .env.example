# ══════════════════════════════════════════════════
#  CONFIGURACIÓN DEL CLIENTE
#  Copia este archivo como .env y rellena los valores
#  NUNCA subas el .env a GitHub
# ══════════════════════════════════════════════════

# Slug del cliente (minúsculas, sin espacios, sin guiones bajos).
# Se usa para nombrar los containers: ${NOMBRE}-core-1, ${NOMBRE}-sara-1, ...
NOMBRE=restaurante

# Dominio fallback nip.io (siempre funciona, sin DNS).
DOMINIO=restaurante.187.127.224.152.nip.io

# Dominio paraguas para los subdominios planos del cliente.
# Resultado: ${NOMBRE}.${DOMINIO_PADRE}, admin-${NOMBRE}.${DOMINIO_PADRE}, etc.
DOMINIO_PADRE=atheniadigital.es
