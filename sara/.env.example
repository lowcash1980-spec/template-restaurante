ANTHROPIC_API_KEY=sk-ant-...
ADMIN_PIN=1234
RESTAURANTE_WHATSAPP=678000000
DEMO_MODE=false

# IMPORTANTE — usar SIEMPRE el nombre de container completo del cliente
# (NUNCA alias genéricos "core", "crm" porque colisionan en la red easypanel
# compartida con otros clientes y resuelven al servicio equivocado).
# Sustituir <cliente> por el slug del cliente (mismo valor que NOMBRE en el .env raíz).
CORE_URL=http://<cliente>-core-1:8000
CRM_URL=http://<cliente>-crm-1:8003
DELIVERY_URL=http://<cliente>-delivery-1:8000

WHATSAPP_PROVIDER=twilio
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_PHONE_NUMBER=+14155238886

# Seguridad: clave para autenticar /api/notificar (vacío = sin auth, dev only)
INTERNAL_KEY=
