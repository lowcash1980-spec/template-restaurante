ADMIN_PASS=cambia_esta_contraseña
NOMBRE_NEGOCIO=Mi Restaurante
ESLOGAN_NEGOCIO=Pedidos a domicilio y recogida
TELEFONO_NEGOCIO=600000000
BRAND_COLOR=#FF6B35
HORARIO_INICIO=13:00
HORARIO_FIN=23:00
MAX_DOMICILIO=2
MAX_RECOGIDA=3
RESERVA_SEGUNDOS=90
# Días cerrados: 1=lunes, 2=martes … 7=domingo. Ej: "1,2" cierra lunes y martes. Vacío=abierto todos.
DIAS_CERRADO=
# IMPORTANTE — usar SIEMPRE el nombre de container completo del cliente
# (NUNCA alias genéricos "core", "crm", "sara": colisionan en la red easypanel
# compartida con otros clientes y resuelven al servicio equivocado).
# Sustituir <cliente> por el slug del cliente (mismo valor que NOMBRE en el .env raíz).
CORE_URL=http://<cliente>-core-1:8000
CRM_URL=http://<cliente>-crm-1:8003
SARA_URL=http://<cliente>-sara-1:8002
